{
  "name": "eazydl-node",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/easydl",
    "typecheck": "tsc --noEmit",
    "verify:ui": "node scripts/verify-ui.mjs",
    "check": "bun run typecheck && bun run build && npm run verify:ui"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "cheerio": "^1.2.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "chromium-bidi": "0.5.24",
    "playwright": "^1.50.0"
  }
}
